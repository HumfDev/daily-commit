{
  "name": "create-daily-commit",
  "version": "0.1.0",
  "description": "Deterministic, no-AI daily automation that keeps connected repos looking alive: safe commits, PR reviews, pull requests, and issues — driven entirely by git/gh CLI commands, never by model inference.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "create-daily-commit": "./bin/install-daily-commit.cjs",
    "dc": "./bin/install-daily-commit.cjs"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "config.yml",
    "repos.yml",
    ".github/",
    "README.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HumfDev/daily-commit.git"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}

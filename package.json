{
  "name": "create-daily-commit",
  "version": "0.1.0",
  "description": "Scaffold and run daily-commit: deterministic, no-AI GitHub repo maintenance via git/gh.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "create-daily-commit": "./dist/index.js",
    "dc": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm run build && npm pack --dry-run",
    "publish:dry": "bash scripts/publish.sh",
    "publish:npm": "bash scripts/publish.sh --upload"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HumfDev/daily-commit.git"
  },
  "homepage": "https://github.com/HumfDev/daily-commit#readme",
  "bugs": {
    "url": "https://github.com/HumfDev/daily-commit/issues"
  },
  "keywords": [
    "github",
    "cli",
    "automation",
    "daily-commit",
    "create-"
  ],
  "dependencies": {
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
